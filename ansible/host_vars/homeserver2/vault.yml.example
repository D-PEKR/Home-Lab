---
# Template für ansible/host_vars/homeserver2/vault.yml
#
# Diese Datei NICHT committen — liegt in .gitignore.
# Die echte vault.yml mit verschlüsselten Werten manuell anlegen:
#
#   ansible-vault encrypt_string 'DEIN_BECOME_PW'  --name 'vault_homeserver2_become_password'
#   ansible-vault encrypt_string 'DEIN_DB_PW'      --name 'vault_paperless_db_password'
#   ansible-vault encrypt_string 'DEIN_ADMIN_PW'   --name 'vault_paperless_admin_password'
#   ansible-vault encrypt_string 'DEIN_SECRET_KEY' --name 'vault_paperless_secret_key'
#
# Ergebnis in vault.yml einfügen:
#
# vault_homeserver2_become_password: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   ...
# vault_paperless_db_password: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   ...
# vault_paperless_admin_password: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   ...
# vault_paperless_secret_key: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   ...
#
# Optional (nur wenn genutzt):
# vault_day_pilot_openai_api_key: !vault | ...
# vault_day_pilot_github_token: !vault | ...
